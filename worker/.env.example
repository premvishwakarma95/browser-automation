# ============================================================
# Python Automation Worker — environment variables
# Copy this file to `.env` and fill in the values.
# ============================================================

# --- Supabase (THIS PROJECT'S OWN database) ---------------------------------
# IMPORTANT: This must be a NEW, SEPARATE Supabase project — NOT the alzato one
# and NOT the enquiry-app one. Create a fresh project at https://database.new
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # service role key (server-side worker only)

# --- MiniMax (the LLM that drives the browser agent) ------------------------
# MiniMax exposes an OpenAI-compatible API. Get these from your MiniMax console.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1   # verify against your MiniMax region/console
MINIMAX_MODEL=                       # e.g. MiniMax-Text-01  (use the model you have access to)

# --- cloakbrowser (stealth Chromium) ---------------------------------------
# Wrapper is free; Chromium v146 is free, v148+ needs a Pro license key.
# Leave blank to use the free version.
CLOAK_LICENSE_KEY=
CLOAK_HUMANIZE=true                  # human-like mouse/keyboard/scroll
CLOAK_GEOIP=true                     # match locale to proxy/IP (useful for Italian portals)
PROXY_URL=                           # optional: http://user:pass@host:port (e.g. an Italian proxy)

# --- Worker runtime ---------------------------------------------------------
HEADLESS=false                       # false = watch the browser while developing
SCREENSHOT_DIR=./screenshots
POLL_INTERVAL_SECONDS=5              # how often to check the DB for new jobs
